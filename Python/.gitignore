# Example data.
#
# The raw NetCDF files are NOT committed: they are downloaded on first use
# from the Zenodo archive (DOI 10.5281/zenodo.20361229) and cached in
# examples/, with md5 verification (see examples/_data.py). So ignore every
# .nc in examples/ ...
examples/*.nc

# ... EXCEPT the small committed derived artifact: the spatial-mean slope
# time series for the full 60 s record, produced once by
# tools/precompute_mean_wave.py and consumed by
# examples/_data.py:mean_wave_timeseries() to reconstruct eta_long(t) offline.
!examples/asit2019_mean_slope_60s.nc

# Python build / cache artifacts
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
build/
dist/
*.part
