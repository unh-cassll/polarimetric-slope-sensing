def _limits(arrays, signed, p=99.5):
    # Common (vmin, vmax) across a list of arrays.
    flat = np.concatenate([np.asarray(a).ravel() for a in arrays])
    if signed:
        v = np.nanpercentile(np.abs(flat), p)
        return -v, v
    return tuple(np.nanpercentile(flat, [100 - p, p]))


def show(ax, data, title, signed=False, p=99.5, stride=3,
         vmin=None, vmax=None, colorbar=True):
    # Grayscale imshow. If vmin/vmax are given they win; else derive from data.
    d = np.asarray(data)[::stride, ::stride]
    if vmin is None or vmax is None:
        vmin, vmax = _limits([d], signed, p)
    im = ax.imshow(d, cmap="gray", vmin=vmin, vmax=vmax, interpolation="nearest")
    ax.set_title(title, fontsize=10)
    ax.set_xticks([]); ax.set_yticks([])
    if colorbar:
        ax.figure.colorbar(im, ax=ax, fraction=0.046, pad=0.04)
    return im


def show_group(fig, axes, datas, titles, signed=False, p=99.5, stride=3,
               cbar_label=None):
    # Show several COMPARABLE panels on a shared scale with ONE colorbar.
    vmin, vmax = _limits([np.asarray(d)[::stride, ::stride] for d in datas],
                         signed, p)
    axes = np.atleast_1d(axes).ravel()
    im = None
    for ax, d, t in zip(axes, datas, titles):
        im = show(ax, d, t, signed=signed, stride=stride,
                  vmin=vmin, vmax=vmax, colorbar=False)
    fig.colorbar(im, ax=list(axes), fraction=0.046, pad=0.04, label=cbar_label)
    return vmin, vmax





