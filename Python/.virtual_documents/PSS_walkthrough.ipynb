t_eta, eta_long = _data.mean_wave_timeseries(verbose=True)

fig, ax = plt.subplots(figsize=(9, 3.2), constrained_layout=True)
ax.plot(t_eta, eta_long, lw=1.2, color="#3b2f8f")
ax.set_xlabel("t [s]")
