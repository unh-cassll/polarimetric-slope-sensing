dolp_raw = res_none.dolp.ravel()
dolp_gain = res_gain.dolp.ravel()
edges = np.linspace(theta_i - 3.0, theta_i + 3.5, 12)
which = np.digitize(aoi_g, edges)
xc, y_raw, y_gain = [], [], []
for b in range(1, len(edges)):
    m = which == b
    if m.sum() > 500:
        xc.append(0.5 * (edges[b - 1] + edges[b]))
        y_raw.append(np.nanmean(dolp_raw[m]))
        y_gain.append(np.nanmean(dolp_gain[m]))
xc, y_raw, y_gain = map(np.array, (xc, y_raw, y_gain))

