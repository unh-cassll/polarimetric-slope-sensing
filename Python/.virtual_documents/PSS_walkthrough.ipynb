print(f"eta_long: {eta_long.size} samples @ "
      f"{1/(t_eta[1]-t_eta[0]):.0f} Hz, std = {eta_long.std()*100:.1f} cm")





from scipy.signal import butter, filtfilt, correlate, correlation_lags

t_lid, lid = _data.lidar_elevation()
fs_eta = 1.0 / (t_eta[1] - t_eta[0])
fs_lid = 1.0 / (t_lid[1] - t_lid[0])
print(f"eta_long : {eta_long.size} @ {fs_eta:.0f} Hz, std {eta_long.std()*100:.1f} cm")
print(f"lidar    : {lid.size} @ {fs_lid:.0f} Hz, std {lid.std()*100:.1f} cm")

def _resample(t, y, fs):
    n = int((t[-1] - t[0]) * fs) + 1
    tg = t[0] + np.arange(n) / fs
    return tg, np.interp(tg, t, y)

def _bandpass(y, fs, lo, hi):
    nyq = fs / 2
    b, a = butter(4, [lo/nyq, min(hi/nyq, 0.99)], btype="band")
    return filtfilt(b, a, y)

# common rate = the lower of the two; band-limit to the swell/long band
fs = min(fs_eta, fs_lid)
F_LO, F_HI = 0.05, 0.5
_, eta_r = _resample(t_eta, eta_long, fs)
_, lid_r = _resample(t_lid, lid, fs)
eta_bp = _bandpass(eta_r, fs, F_LO, F_HI)
lid_bp = _bandpass(lid_r, fs, F_LO, F_HI)


# cross-correlate over the overlap (PSS is the shorter record); search +/-30 s
MAX_LAG = 30.0
n_eta = eta_bp.size
pad = int(MAX_LAG * fs)
seg = lid_bp[:n_eta + pad]
a = (eta_bp - eta_bp.mean()) / (eta_bp.std() + 1e-30)
b = (seg - seg.mean()) / (seg.std() + 1e-30)
xc = correlate(b, a, mode="full") / min(a.size, b.size)
lags = correlation_lags(b.size, a.size, mode="full") / fs
keep = np.abs(lags) <= MAX_LAG
lags_k, xc_k = lags[keep], xc[keep]
lag_peak = lags_k[np.argmax(xc_k)]
r_broad = xc_k.max()

# Keep ONLY the genuine overlap window (where both series exist after the
# lag shift), and recompute the correlation there -- the honest comparison.
te = np.arange(n_eta) / fs
tl_full = np.arange(lid_bp.size) / fs - lag_peak
t0 = max(te[0], tl_full[0]); t1 = min(te[-1], tl_full[-1])
mask = (te >= t0) & (te <= t1)
t_ov = te[mask]; eta_ov = eta_bp[mask]
lid_ov = np.interp(t_ov, tl_full, lid_bp)
r_ov = float(np.corrcoef(eta_ov, lid_ov)[0, 1])
print(f"peak lag = {lag_peak:+.2f} s | broadband r = {r_broad:.3f} | "
      f"overlap r = {r_ov:.3f} over {t_ov[-1]-t_ov[0]:.0f} s")
print(f"band-passed std: eta_long {eta_ov.std()*100:.1f} cm vs "
      f"lidar {lid_ov.std()*100:.1f} cm (ratio {eta_ov.std()/lid_ov.std():.2f})")

fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(9, 7), constrained_layout=True)
ax1.plot(t_ov, eta_ov, lw=1.5, color="#3b2f8f", label=r"PSS $\eta_{long}$")
ax1.plot(t_ov, lid_ov, lw=1.2, alpha=0.85, color="#d2691e",
         label=f"Riegl lidar (aligned, shifted {-lag_peak:+.2f} s)")
ax1.set_xlim(t_ov[0], t_ov[-1]); ax1.set_xlabel("t [s]  (PSS clock)")
ax1.set_ylabel("elevation [m]")
ax1.set_title(f"PSS $\eta_{{long}}$ vs Riegl lidar, overlap "
              f"(band {F_LO}-{F_HI} Hz, r = {r_ov:.2f})")
ax1.legend(loc="upper right"); ax1.grid(alpha=0.3)
ax2.plot(lags_k, xc_k, lw=1.4, color="#3b2f8f")
ax2.axvline(lag_peak, color="k", ls="--", lw=1,
            label=f"peak lag {lag_peak:+.2f} s, r={r_broad:.2f}")
ax2.set_xlabel("lag [s]  (PSS relative to lidar)")
ax2.set_ylabel("normalised cross-correlation")
ax2.set_title("Cross-correlation (lag finder)")
ax2.legend(loc="upper right"); ax2.grid(alpha=0.3)



